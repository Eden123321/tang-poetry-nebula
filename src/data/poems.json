[
  {"id": 1, "title": "静夜思", "author": "李白", "dynasty": "Tang", "content": ["床前明月光", "疑是地上霜", "举头望明月", "低头思故乡"]},
  {"id": 2, "title": "春晓", "author": "孟浩然", "dynasty": "Tang", "content": ["春眠不觉晓", "处处闻啼鸟", "夜来风雨声", "花落知多少"]},
  {"id": 3, "title": "登鹳雀楼", "author": "王之涣", "dynasty": "Tang", "content": ["白日依山尽", "黄河入海流", "欲穷千里目", "更上一层楼"]},
  {"id": 4, "title": "相思", "author": "王维", "dynasty": "Tang", "content": ["红豆生南国", "春来发几枝", "愿君多采撷", "此物最相思"]},
  {"id": 5, "title": "江雪", "author": "柳宗元", "dynasty": "Tang", "content": ["千山鸟飞绝", "万径人踪灭", "孤舟蓑笠翁", "独钓寒江雪"]},
  {"id": 6, "title": "鹿柴", "author": "王维", "dynasty": "Tang", "content": ["空山不见人", "但闻人语响", "返景入深林", "复照青苔上"]},
  {"id": 7, "title": "悯农", "author": "李绅", "dynasty": "Tang", "content": ["锄禾日当午", "汗滴禾下土", "谁知盘中餐", "粒粒皆辛苦"]},
  {"id": 8, "title": "游子吟", "author": "孟郊", "dynasty": "Tang", "content": ["慈母手中线", "游子身上衣", "临行密密缝", "意恐迟迟归"]},
  {"id": 9, "title": "宿建德江", "author": "孟浩然", "dynasty": "Tang", "content": ["移舟泊烟渚", "日暮客愁新", "野旷天低树", "江清月近人"]},
  {"id": 10, "title": "秋浦歌", "author": "李白", "dynasty": "Tang", "content": ["白发三千丈", "缘愁似个长", "不知明镜里", "何处得秋霜"]},
  {"id": 11, "title": "望庐山瀑布", "author": "李白", "dynasty": "Tang", "content": ["日照香炉生紫烟", "遥看瀑布挂前川", "飞流直下三千尺", "疑是银河落九天"]},
  {"id": 12, "title": "送别", "author": "王维", "dynasty": "Tang", "content": ["下马饮君酒", "问君何所之", "君言不得意", "归卧南山陲"]},
  {"id": 13, "title": "九月九日忆山东兄弟", "author": "王维", "dynasty": "Tang", "content": ["独在异乡为异客", "每逢佳节倍思亲", "遥知兄弟登高处", "遍插茱萸少一人"]},
  {"id": 14, "title": "黄鹤楼送孟浩然之广陵", "author": "李白", "dynasty": "Tang", "content": ["故人西辞黄鹤楼", "烟花三月下扬州", "孤帆远影碧空尽", "唯见长江天际流"]},
  {"id": 15, "title": "早发白帝城", "author": "李白", "dynasty": "Tang", "content": ["朝辞白帝彩云间", "千里江陵一日还", "两岸猿声啼不住", "轻舟已过万重山"]},
  {"id": 16, "title": "望天门山", "author": "李白", "dynasty": "Tang", "content": ["天门中断楚江开", "碧水东流至此回", "两岸青山相对出", "孤帆一片日边来"]},
  {"id": 17, "title": "绝句", "author": "杜甫", "dynasty": "Tang", "content": ["两个黄鹂鸣翠柳", "一行白鹭上青天", "窗含西岭千秋雪", "门泊东吴万里船"]},
  {"id": 18, "title": "春望", "author": "杜甫", "dynasty": "Tang", "content": ["国破山河在", "城春草木深", "感时花溅泪", "恨别鸟惊心"]},
  {"id": 19, "title": "月夜", "author": "杜甫", "dynasty": "Tang", "content": ["今夜鄜州月", "闺中只独看", "遥怜小儿女", "未解忆长安"]},
  {"id": 20, "title": "月夜忆舍弟", "author": "杜甫", "dynasty": "Tang", "content": ["露从今夜白", "月是故乡明", "有弟皆分散", "无家问死生"]},
  {"id": 21, "title": "登高", "author": "杜甫", "dynasty": "Tang", "content": ["风急天高猿啸哀", "渚清沙白鸟飞回", "无边落木萧萧下", "不尽长江滚滚来"]},
  {"id": 22, "title": "枫桥夜泊", "author": "张继", "dynasty": "Tang", "content": ["月落乌啼霜满天", "江枫渔火对愁眠", "姑苏城外寒山寺", "夜半钟声到客船"]},
  {"id": 23, "title": "滁州西涧", "author": "韦应物", "dynasty": "Tang", "content": ["独怜幽草涧边生", "上有黄鹂深树鸣", "春潮带雨晚来急", "野渡无人舟自横"]},
  {"id": 24, "title": "寒食", "author": "韩翃", "dynasty": "Tang", "content": ["春城无处不飞花", "寒食东风御柳斜", "日暮汉宫传蜡烛", "轻烟散入五侯家"]},
  {"id": 25, "title": "清明", "author": "杜牧", "dynasty": "Tang", "content": ["清明时节雨纷纷", "路上行人欲断魂", "借问酒家何处有", "牧童遥指杏花村"]},
  {"id": 26, "title": "山行", "author": "杜牧", "dynasty": "Tang", "content": ["远上寒山石径斜", "白云生处有人家", "停车坐爱枫林晚", "霜叶红于二月花"]},
  {"id": 27, "title": "江南春", "author": "杜牧", "dynasty": "Tang", "content": ["千里莺啼绿映红", "水村山郭酒旗风", "南朝四百八十寺", "多少楼台烟雨中"]},
  {"id": 28, "title": "泊秦淮", "author": "杜牧", "dynasty": "Tang", "content": ["烟笼寒水月笼沙", "夜泊秦淮近酒家", "商女不知亡国恨", "隔江犹唱后庭花"]},
  {"id": 29, "title": "寄扬州韩绰判官", "author": "杜牧", "dynasty": "Tang", "content": ["青山隐隐水迢迢", "秋尽江南草未凋", "二十四桥明月夜", "玉人何处教吹箫"]},
  {"id": 30, "title": "夜雨寄北", "author": "李商隐", "dynasty": "Tang", "content": ["君问归期未有期", "巴山夜雨涨秋池", "何当共剪西窗烛", "却话巴山夜雨时"]},
  {"id": 31, "title": "锦瑟", "author": "李商隐", "dynasty": "Tang", "content": ["锦瑟无端五十弦", "一弦一柱思华年", "庄生晓梦迷蝴蝶", "望帝春心托杜鹃"]},
  {"id": 32, "title": "无题", "author": "李商隐", "dynasty": "Tang", "content": ["相见时难别亦难", "东风无力百花残", "春蚕到死丝方尽", "蜡炬成灰泪始干"]},
  {"id": 33, "title": "登乐游原", "author": "李商隐", "dynasty": "Tang", "content": ["向晚意不适", "驱车登古原", "夕阳无限好", "只是近黄昏"]},
  {"id": 34, "title": "寻隐者不遇", "author": "贾岛", "dynasty": "Tang", "content": ["松下问童子", "言师采药去", "只在此山中", "云深不知处"]},
  {"id": 35, "title": "题李凝幽居", "author": "贾岛", "dynasty": "Tang", "content": ["闲居少邻并", "草径入荒园", "鸟宿池边树", "僧敲月下门"]},
  {"id": 36, "title": "逢雪宿芙蓉山主人", "author": "刘长卿", "dynasty": "Tang", "content": ["日暮苍山远", "天寒白屋贫", "柴门闻犬吠", "风雪夜归人"]},
  {"id": 37, "title": "送灵澈上人", "author": "刘长卿", "dynasty": "Tang", "content": ["苍苍竹林寺", "杳杳钟声晚", "荷笠带斜阳", "青山独归远"]},
  {"id": 38, "title": "弹琴", "author": "刘长卿", "dynasty": "Tang", "content": ["泠泠七弦上", "静听松风寒", "古调虽自爱", "今人多不弹"]},
  {"id": 39, "title": "送上人", "author": "刘长卿", "dynasty": "Tang", "content": ["孤云将野鹤", "岂向人间住", "莫买沃洲山", "时人已知处"]},
  {"id": 40, "title": "江村即事", "author": "司空曙", "dynasty": "Tang", "content": ["钓罢归来不系船", "江村月落正堪眠", "纵然一夜风吹去", "只在芦花浅水边"]},
  {"id": 41, "title": "小儿垂钓", "author": "胡令能", "dynasty": "Tang", "content": ["蓬头稚子学垂纶", "侧坐莓苔草映身", "路人借问遥招手", "怕得鱼惊不应人"]},
  {"id": 42, "title": "咏鹅", "author": "骆宾王", "dynasty": "Tang", "content": ["鹅鹅鹅", "曲项向天歌", "白毛浮绿水", "红掌拨清波"]},
  {"id": 43, "title": "风", "author": "李峤", "dynasty": "Tang", "content": ["解落三秋叶", "能开二月花", "过江千尺浪", "入竹万竿斜"]},
  {"id": 44, "title": "咏柳", "author": "贺知章", "dynasty": "Tang", "content": ["碧玉妆成一树高", "万条垂下绿丝绦", "不知细叶谁裁出", "二月春风似剪刀"]},
  {"id": 45, "title": "回乡偶书", "author": "贺知章", "dynasty": "Tang", "content": ["少小离家老大回", "乡音无改鬓毛衰", "儿童相见不相识", "笑问客从何处来"]},
  {"id": 46, "title": "凉州词", "author": "王翰", "dynasty": "Tang", "content": ["葡萄美酒夜光杯", "欲饮琵琶马上催", "醉卧沙场君莫笑", "古来征战几人回"]},
  {"id": 47, "title": "出塞", "author": "王昌龄", "dynasty": "Tang", "content": ["秦时明月汉时关", "万里长征人未还", "但使龙城飞将在", "不教胡马度阴山"]},
  {"id": 48, "title": "芙蓉楼送辛渐", "author": "王昌龄", "dynasty": "Tang", "content": ["寒雨连江夜入吴", "平明送客楚山孤", "洛阳亲友如相问", "一片冰心在玉壶"]},
  {"id": 49, "title": "闺怨", "author": "王昌龄", "dynasty": "Tang", "content": ["闺中少妇不知愁", "春日凝妆上翠楼", "忽见陌头杨柳色", "悔教夫婿觅封侯"]},
  {"id": 50, "title": "长信秋词", "author": "王昌龄", "dynasty": "Tang", "content": ["奉帚平明金殿开", "暂将团扇共徘徊", "玉颜不及寒鸦色", "犹带昭阳日影来"]},
  {"id": 51, "title": "从军行", "author": "王昌龄", "dynasty": "Tang", "content": ["青海长云暗雪山", "孤城遥望玉门关", "黄沙百战穿金甲", "不破楼兰终不还"]},
  {"id": 52, "title": "采莲曲", "author": "王昌龄", "dynasty": "Tang", "content": ["荷叶罗裙一色裁", "芙蓉向脸两边开", "乱入池中看不见", "闻歌始觉有人来"]},
  {"id": 53, "title": "凉州词", "author": "王之涣", "dynasty": "Tang", "content": ["黄河远上白云间", "一片孤城万仞山", "羌笛何须怨杨柳", "春风不度玉门关"]},
  {"id": 54, "title": "送元二使安西", "author": "王维", "dynasty": "Tang", "content": ["渭城朝雨浥轻尘", "客舍青青柳色新", "劝君更尽一杯酒", "西出阳关无故人"]},
  {"id": 55, "title": "使至塞上", "author": "王维", "dynasty": "Tang", "content": ["单车欲问边", "属国过居延", "征蓬出汉塞", "归雁入胡天"]},
  {"id": 56, "title": "山居秋暝", "author": "王维", "dynasty": "Tang", "content": ["空山新雨后", "天气晚来秋", "明月松间照", "清泉石上流"]},
  {"id": 57, "title": "鸟鸣涧", "author": "王维", "dynasty": "Tang", "content": ["人闲桂花落", "夜静春山空", "月出惊山鸟", "时鸣春涧中"]},
  {"id": 58, "title": "竹里馆", "author": "王维", "dynasty": "Tang", "content": ["独坐幽篁里", "弹琴复长啸", "深林人不知", "明月来相照"]},
  {"id": 59, "title": "送别", "author": "王维", "dynasty": "Tang", "content": ["山中相送罢", "日暮掩柴扉", "春草明年绿", "王孙归不归"]},
  {"id": 60, "title": "杂诗", "author": "王维", "dynasty": "Tang", "content": ["君自故乡来", "应知故乡事", "来日后窗前", "寒梅著花未"]},
  {"id": 61, "title": "行宫", "author": "元稹", "dynasty": "Tang", "content": ["寥落古行宫", "宫花寂寞红", "白头宫女在", "闲坐说玄宗"]},
  {"id": 62, "title": "菊花", "author": "元稹", "dynasty": "Tang", "content": ["秋丛绕舍似陶家", "遍绕篱边日渐斜", "不是花中偏爱菊", "此花开尽更无花"]},
  {"id": 63, "title": "离思", "author": "元稹", "dynasty": "Tang", "content": ["曾经沧海难为水", "除却巫山不是云", "取次花丛懒回顾", "半缘修道半缘君"]},
  {"id": 64, "title": "闻乐天授江州司马", "author": "元稹", "dynasty": "Tang", "content": ["残灯无焰影幢幢", "此夕闻君谪九江", "垂死病中惊坐起", "暗风吹雨入寒窗"]},
  {"id": 65, "title": "遣悲怀", "author": "元稹", "dynasty": "Tang", "content": ["昔日戏言身后事", "今朝都到眼前来", "衣裳已施行看尽", "针线犹存未忍开"]},
  {"id": 66, "title": "登岳阳楼", "author": "杜甫", "dynasty": "Tang", "content": ["昔闻洞庭水", "今上岳阳楼", "吴楚东南坼", "乾坤日夜浮"]},
  {"id": 67, "title": "野望", "author": "杜甫", "dynasty": "Tang", "content": ["东皋薄暮望", "徙倚欲何依", "树树皆秋色", "山山唯落晖"]},
  {"id": 68, "title": "望岳", "author": "杜甫", "dynasty": "Tang", "content": ["岱宗夫如何", "齐鲁青未了", "会当凌绝顶", "一览众山小"]},
  {"id": 69, "title": "赠花卿", "author": "杜甫", "dynasty": "Tang", "content": ["锦城丝管日纷纷", "半入江风半入云", "此情只应天上有", "人间能得几回闻"]},
  {"id": 70, "title": "江南逢李龟年", "author": "杜甫", "dynasty": "Tang", "content": ["岐王宅里寻常见", "崔九堂前几度闻", "正是江南好风景", "落花时节又逢君"]},
  {"id": 71, "title": "赠汪伦", "author": "李白", "dynasty": "Tang", "content": ["李白乘舟将欲行", "忽闻涛声踏歌声", "桃花潭水深千尺", "不及汪伦送我情"]},
  {"id": 72, "title": "行路难", "author": "李白", "dynasty": "Tang", "content": ["金樽清酒斗十千", "玉盘珍羞直万钱", "长风破浪会有时", "直挂云帆济沧海"]},
  {"id": 73, "title": "将进酒", "author": "李白", "dynasty": "Tang", "content": ["君不见黄河之水天上来", "奔流到海不复回", "人生得意须尽欢", "莫使金樽空对月"]},
  {"id": 74, "title": "峨眉山月歌", "author": "李白", "dynasty": "Tang", "content": ["峨眉山月半轮秋", "影入平羌江水流", "夜发清溪向三峡", "思君不见下渝州"]},
  {"id": 75, "title": "渡荆门送别", "author": "李白", "dynasty": "Tang", "content": ["渡远荆门外", "来从楚国游", "山随平野尽", "江入大荒流"]},
  {"id": 76, "title": "送友人", "author": "李白", "dynasty": "Tang", "content": ["青山横北郭", "白水绕东城", "此地一为别", "孤蓬万里征"]},
  {"id": 77, "title": "宣州谢朓楼饯别校书叔云", "author": "李白", "dynasty": "Tang", "content": ["弃我去者昨日之日不可留", "乱我心者今日之日多烦忧", "抽刀断水水更流", "举杯消愁愁更愁"]},
  {"id": 78, "title": "客中作", "author": "李白", "dynasty": "Tang", "content": ["兰陵美酒郁金香", "玉碗盛来琥珀光", "但使主人能醉客", "不知何处是他乡"]},
  {"id": 79, "title": "越中览古", "author": "李白", "dynasty": "Tang", "content": ["越王勾践破吴归", "义士还家尽锦衣", "宫娥满殿花如锦", "只今唯有鹧鸪飞"]},
  {"id": 80, "title": "望夫石", "author": "王建", "dynasty": "Tang", "content": ["望夫处，江悠悠", "化为石，不回头", "山头日日风复雨", "行人归来石应语"]},
  {"id": 81, "title": "雨过山村", "author": "王建", "dynasty": "Tang", "content": ["雨里鸡鸣一两家", "竹溪村路板桥斜", "妇姑相唤浴蚕去", "闲著中庭栀子花"]},
  {"id": 82, "title": "十五夜望月", "author": "王建", "dynasty": "Tang", "content": ["中庭地白树栖鸦", "冷露无声湿桂花", "今夜月明人尽望", "不知秋思落谁家"]},
  {"id": 83, "title": "新嫁娘", "author": "王建", "dynasty": "Tang", "content": ["三日入厨下", "洗手作羹汤", "未谙姑食性", "先遣小姑尝"]},
  {"id": 84, "title": "宫词", "author": "王建", "dynasty": "Tang", "content": ["树头树底觅残红", "一片西飞一片东", "自是桃花贪结子", "错教人恨五更风"]},
  {"id": 85, "title": "秋词", "author": "刘禹锡", "dynasty": "Tang", "content": ["自古逢秋悲寂寥", "我言秋日胜春朝", "晴空一鹤排云上", "便引诗情到碧霄"]},
  {"id": 86, "title": "竹枝词", "author": "刘禹锡", "dynasty": "Tang", "content": ["杨柳青青江水平", "闻郎江上唱歌声", "东边日出西边雨", "道是无晴却有晴"]},
  {"id": 87, "title": "浪淘沙", "author": "刘禹锡", "dynasty": "Tang", "content": ["九曲黄河万里沙", "浪淘风簸自天涯", "如今直上银河去", "同到牵牛织女家"]},
  {"id": 88, "title": "乌衣巷", "author": "刘禹锡", "dynasty": "Tang", "content": ["朱雀桥边野草花", "乌衣巷口夕阳斜", "旧时王谢堂前燕", "飞入寻常百姓家"]},
  {"id": 89, "title": "望洞庭", "author": "刘禹锡", "dynasty": "Tang", "content": ["湖光秋月两相和", "潭面无风镜未磨", "遥望洞庭山水翠", "白银盘里一青螺"]},
  {"id": 90, "title": "再游玄都观", "author": "刘禹锡", "dynasty": "Tang", "content": ["百亩庭中半是苔", "桃花净尽菜花开", "种桃道士归何处", "前度刘郎今又来"]},
  {"id": 91, "title": "石头城", "author": "刘禹锡", "dynasty": "Tang", "content": ["山围故国周遭在", "潮打空城寂寞回", "淮水东边旧时月", "夜深还过女墙来"]},
  {"id": 92, "title": "西塞山怀古", "author": "刘禹锡", "dynasty": "Tang", "content": ["王浚楼船下益州", "金陵王气黯然收", "千寻铁锁沉江底", "一片降幡出石头"]},
  {"id": 93, "title": "赋得古原草送别", "author": "白居易", "dynasty": "Tang", "content": ["离离原上草", "一岁一枯荣", "野火烧不尽", "春风吹又生"]},
  {"id": 94, "title": "问刘十九", "author": "白居易", "dynasty": "Tang", "content": ["绿蚁新醅酒", "红泥小火炉", "晚来天欲雪", "能饮一杯无"]},
  {"id": 95, "title": "暮江吟", "author": "白居易", "dynasty": "Tang", "content": ["一道残阳铺水中", "半江瑟瑟半江红", "可怜九月初三夜", "露似真珠月似弓"]},
  {"id": 96, "title": "忆江南", "author": "白居易", "dynasty": "Tang", "content": ["江南好", "风景旧曾谙", "日出江花红胜火", "春来江水绿如蓝"]},
  {"id": 97, "title": "长相思", "author": "白居易", "dynasty": "Tang", "content": ["汴水流", "泗水流", "流到瓜洲古渡头", "吴山点点愁"]},
  {"id": 98, "title": "琵琶行", "author": "白居易", "dynasty": "Tang", "content": ["大弦嘈嘈如急雨", "小弦切切如私语", "嘈嘈切切错杂弹", "大珠小珠落玉盘"]},
  {"id": 99, "title": "观刈麦", "author": "白居易", "dynasty": "Tang", "content": ["田家少闲月", "五月人倍忙", "夜来南风起", "小麦覆陇黄"]},
  {"id": 100, "title": "池上", "author": "白居易", "dynasty": "Tang", "content": ["小娃撑小艇", "偷采白莲回", "不解藏踪迹", "浮萍一道开"]}
]